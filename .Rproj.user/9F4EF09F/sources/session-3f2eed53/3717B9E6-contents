# --- SETUP ---

library(dplyr)
library(clusterProfiler)
library(org.Hs.eg.db)
library(AnnotationDbi)
library(data.table)
library(ggplot2)
library(tidyr)
library(gridExtra)
library(here)

# Create output directories if they don't exist
if (!dir.exists(here("results", "correlation_plots"))) {
  dir.create(here("results", "correlation_plots"), recursive = TRUE)
}

# --- DATA LOADING ---
# Load processed matrices from /data
meth <- read.table(here("data", "meth_final.tsv"), header = TRUE, sep = "\t", check.names = FALSE)
geq <- read.table(here("data", "geq_final.tsv"), header = TRUE, sep = "\t", check.names = FALSE)

# Load intersecting genes (generated by script 01 in /results)
intersection_file <- read.table(here("results", "degs_dmgs_intersect.txt"), header = FALSE, sep = "\t", check.names = FALSE)
intersecting_genes <- intersection_file[, 1]

# Filter matrices for intersecting genes
geq <- geq[geq[, 1] %in% intersecting_genes, ]
meth <- meth[meth[, 1] %in% intersecting_genes, ]

# --- SET THRESHOLDS ---
threshold_padj <- 0.05
threshold_cor_pos <- 0.4
threshold_cor_neg <- -0.4

# --- SPEARMAN CORRELATION ANALYSIS ---
spearman_results <- data.frame(
  gene = geq[, 1], 
  correlation = numeric(nrow(geq)),
  p_value = numeric(nrow(geq))
)

geq_data <- geq[, -1]  
meth_data <- meth[, -1]

# Loop through each gene to calculate correlation between expression and methylation
for (i in seq_len(nrow(geq))) {
  expression_values <- as.numeric(geq_data[i, ])
  methylation_values <- as.numeric(meth_data[i, ])
  
  test_result <- cor.test(expression_values, methylation_values, method = "spearman")
  
  spearman_results$correlation[i] <- test_result$estimate
  spearman_results$p_value[i] <- test_result$p.value
}

# Adjust p-values using FDR
spearman_results <- spearman_results %>%
  mutate(p_value_adj = p.adjust(p_value, method = "fdr"))

# Filter for significant correlations
spearman_results <- spearman_results %>%
  filter(p_value_adj < threshold_padj)

# Identify genes with strong negative and positive correlations
genes_neg <- spearman_results$gene[spearman_results$correlation <= threshold_cor_neg]
genes_pos <- spearman_results$gene[spearman_results$correlation >= threshold_cor_pos]

filtered_spearman_results <- spearman_results %>%
  filter(gene %in% c(genes_neg, genes_pos))

# Save the list of correlated genes to /results
cor_gene_list <- filtered_spearman_results$gene
writeLines(cor_gene_list, here("results", "cor_gene_list.txt"))

# --- DATA PREPARATION FOR PLOTTING ---
geq_filt <- geq[geq[, 1] %in% cor_gene_list, ]
meth_filt <- meth[meth[, 1] %in% cor_gene_list, ]

# Reshape data to long format for ggplot
geq_long <- pivot_longer(geq_filt, cols = -1, names_to = "Sample", values_to = "Expression")
meth_long <- pivot_longer(meth_filt, cols = -1, names_to = "Sample", values_to = "Methylation")

# Join expression and methylation data
merged_data <- inner_join(geq_long, meth_long, by = c("Sample", "gene_symbol"))
merged_data$Type <- ifelse(grepl("normal", merged_data$Sample), "Normal", "Tumoral")

# --- INDIVIDUAL GENE PLOTTING ---
# Plot each gene with Rho and Adjusted P-value
for (gene in unique(merged_data$gene_symbol)) {
  data_gene <- subset(merged_data, gene_symbol == gene)
  stats_gene <- filtered_spearman_results %>% filter(gene == !!gene)
  rho <- stats_gene$correlation
  pval_adj <- stats_gene$p_value_adj
  
  p <- ggplot(data_gene, aes(x = Methylation, y = Expression)) +
    geom_point(aes(color = Type), alpha = 0.7) +
    geom_smooth(method = "lm", se = FALSE, color = "gray30", linetype = "dashed") +
    labs(
      x = "Methylation (Beta Value)",
      y = "Expression (FPKM)",
      title = paste("Gene:", gene)
    ) +
    scale_color_manual(values = c("Normal" = "#800020", "Tumoral" = "#006994")) +
    theme_minimal() +
    annotate("text",
             x = min(data_gene$Methylation, na.rm = TRUE),
             y = max(data_gene$Expression, na.rm = TRUE),
             label = paste("rho =", round(rho, 3), "\nFDR =", signif(pval_adj, 3)),
             hjust = 0, vjust = 1, size = 4, color = "black")
  
  # Save plots to results/correlation_plots/
  ggsave(filename = here("results", "correlation_plots", paste0(gene, "_spearman.png")),
         plot = p, width = 6, height = 4)
}


# --- PANEL PLOTTING (GRIDS) ---

# Split data into positive and negative correlation groups
geq_pos <- geq_filt[geq_filt[, 1] %in% genes_pos, ]
meth_pos <- meth_filt[meth_filt[, 1] %in% genes_pos, ]
geq_neg <- geq_filt[geq_filt[, 1] %in% genes_neg, ]
meth_neg <- meth_filt[meth_filt[, 1] %in% genes_neg, ]

# Helper function for long format conversion
to_long_format <- function(geq_df, meth_df) {
  g_long <- pivot_longer(geq_df, cols = -1, names_to = "Sample", values_to = "Expression")
  m_long <- pivot_longer(meth_df, cols = -1, names_to = "Sample", values_to = "Methylation")
  colnames(g_long)[1] <- "gene_symbol"
  colnames(m_long)[1] <- "gene_symbol"
  df <- inner_join(g_long, m_long, by = c("Sample", "gene_symbol"))
  df$Type <- ifelse(grepl("normal", df$Sample), "Normal", "Tumoral")
  return(df)
}

merged_pos <- to_long_format(geq_pos, meth_pos)
merged_neg <- to_long_format(geq_neg, meth_neg)

