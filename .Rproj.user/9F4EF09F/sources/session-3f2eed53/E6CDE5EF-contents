#funzione per unire geni e versioni
#funzione 1
remove_gene_versions <- function(data, column_name = "gene_symbol") {
  # Ensure data is a data.table
  setDT(data)
  
  # Remove version numbers from the specified column
  data[, (column_name) := sub("\\.\\d+$", "", get(column_name))]
  
  return(data)
}

#chiamata
geq_normal_avg <- remove_gene_versions(paad_geq_normal)
geq_tumoral_avg <- remove_gene_versions(paad_geq_tumoral) 

#funzione 2
average_duplicates <- function(data) {
  # Set data as data.table
  setDT(data)
  
  # Calculate mean for each gene_symbol, excluding gene_symbol column from averaging
  averaged_data <- data[, lapply(.SD, mean), by = gene_symbol]
  
  return(averaged_data)
}

#chiamata
